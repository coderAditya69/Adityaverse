<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MoleculeBuilder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_light</item>
        <item name="android:windowBackground">@color/surface_deep</item>
        <item name="materialCardViewStyle">@style/Widget.MoleculeBuilder.Card</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
    </style>

    <style name="Widget.MoleculeBuilder.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#33FFFFFF</item>
    </style>
</resources>
